# Copy this to `.env` and edit as needed. `.env` is gitignored.
#
# `npm run dev` passes --env-file-if-exists=.env to Node, which loads these
# into process.env BEFORE server.ts imports. The frontend (Vite) ignores
# this file — Vite has its own .env handling and only exposes VITE_-prefixed
# variables to the browser.

# Where the CopilotKit Node runtime forwards agent requests. Required —
# server.ts throws at startup if this is unset. Use the local FastAPI URL
# for dev or a deployed URL for staging/prod.
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8000
